# ============================================================================
# CRS-FULL — Arquivo de Configuração de Exemplo
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do arquivo .env no repositório
# ============================================================================

# SERVIDOR
SERVER_PORT=5000
SERVER_HOST=0.0.0.0
NODE_ENV=development

# BANCO DE DADOS
DATABASE_URL=sqlite:///crs_full.db
# Para PostgreSQL, use: postgresql://usuario:senha@localhost:5432/crs_full
# Para MySQL, use: mysql://usuario:senha@localhost:3306/crs_full

# SEGURANÇA E AUTENTICAÇÃO
SECRET_KEY=sua-chave-secreta-super-segura-aqui-minimo-32-caracteres
JWT_EXPIRATION=24h
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/crs_full.log

# SESSÕES
SESSION_TIMEOUT=3600
MAX_SESSIONS_PER_USER=10

# ARMAZENAMENTO
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=52428800

# EMAIL (Opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app

# API EXTERNA (Opcional)
OPENAI_API_KEY=sk-proj-sua-chave-aqui
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# DESENVOLVIMENTO
DEBUG=True
TESTING=False

# ============================================================================
# INSTRUÇÕES
# ============================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais no arquivo .env
# 3. Adicione .env ao .gitignore (já deve estar)
# 4. Nunca faça commit do .env
# ============================================================================